@prefix : <http://example.com#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.com#> .

<http://example.com> rdf:type owl:Ontology ;
                      owl:imports gufo: .

#################################################################
#    Object Properties
#################################################################

###  http://example.com#fundamenta
:fundamenta rdf:type owl:ObjectProperty ;
            rdfs:domain :Valor ;
            rdfs:range :Norma .


###  http://example.com#interage_com
:interage_com rdf:type owl:ObjectProperty ;
              rdfs:domain :Usuario ;
              rdfs:range :AgenteArtificial .


###  http://example.com#redige
:redige rdf:type owl:ObjectProperty ;
        rdfs:domain :Especialista ;
        rdfs:range :Norma .


###  http://example.com#responsabiliza
:responsabiliza rdf:type owl:ObjectProperty ;
                rdfs:domain :OrgaoRegulador ;
                rdfs:range :Agente .


###  http://example.com#se_baseia_em
:se_baseia_em rdf:type owl:ObjectProperty ;
              rdfs:domain :Especialista ;
              rdfs:range :Valor .


###  http://example.com#tem_prioridade_sobre
:tem_prioridade_sobre rdf:type owl:ObjectProperty ;
                      rdfs:domain :Norma ;
                      rdfs:range :Norma .


#################################################################
#    Classes
#################################################################

###  http://example.com#Acao
:Acao rdf:type owl:Class ;
      rdfs:subClassOf gufo:Event ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                       ] ;
                        owl:someValuesFrom :EcossistemaDeIA
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty [ owl:inverseOf gufo:participatedIn
                                       ] ;
                        owl:someValuesFrom :Usuario
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty [ owl:inverseOf gufo:wasCreatedIn
                                       ] ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :AgenteArtificial
                      ] .


###  http://example.com#AcaoMoral
:AcaoMoral rdf:type owl:Class ;
           rdfs:subClassOf :Acao ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                            ] ;
                             owl:someValuesFrom :Norma
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty [ owl:inverseOf gufo:participatedIn
                                            ] ;
                             owl:someValuesFrom :AgenteMoral
                           ] .


###  http://example.com#Agente
:Agente rdf:type owl:Class ;
        rdfs:subClassOf gufo:FunctionalComplex ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty [ owl:inverseOf gufo:mediates
                                         ] ;
                          owl:someValuesFrom :Responsabilizacao
                        ] .


###  http://example.com#AgenteArtificial
:AgenteArtificial rdf:type owl:Class ;
                  rdfs:subClassOf :Agente ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty gufo:wasCreatedIn ;
                                    owl:someValuesFrom :Acao
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty [ owl:inverseOf gufo:mediates
                                                   ] ;
                                    owl:someValuesFrom :EcossistemaDeIA
                                  ] .


###  http://example.com#AgenteColetivo
:AgenteColetivo rdf:type owl:Class ;
                rdfs:subClassOf :Agente .


###  http://example.com#AgenteHumano
:AgenteHumano rdf:type owl:Class ;
              rdfs:subClassOf :Agente .


###  http://example.com#AgenteMoral
:AgenteMoral rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Agente
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty [ owl:inverseOf gufo:mediates
                                                                         ] ;
                                                          owl:someValuesFrom :Norma
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] .


###  http://example.com#AplicacaoDeResponsabilidade
:AplicacaoDeResponsabilidade rdf:type owl:Class ;
                             rdfs:subClassOf gufo:Event ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                              ] ;
                                               owl:someValuesFrom :Responsabilizacao
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                              ] ;
                                               owl:someValuesFrom :Agente
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                              ] ;
                                               owl:someValuesFrom :OrgaoRegulador
                                             ] .


###  http://example.com#AplicacaoNormativa
:AplicacaoNormativa rdf:type owl:Class ;
                    rdfs:subClassOf gufo:Situation .


###  http://example.com#Beneficencia
:Beneficencia rdf:type owl:Class ;
              rdfs:subClassOf :Valor .


###  http://example.com#DefinicaoNormativa
:DefinicaoNormativa rdf:type owl:Class ;
                    rdfs:subClassOf gufo:Relator ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty gufo:mediates ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass :Especialista
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty gufo:mediates ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass :Norma
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty gufo:mediates ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass :Valor
                                    ] .


###  http://example.com#EcossistemaDeIA
:EcossistemaDeIA rdf:type owl:Class ;
                 rdfs:subClassOf gufo:Relator ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty gufo:mediates ;
                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :AgenteArtificial
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty gufo:mediates ;
                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :Usuario
                                 ] .


###  http://example.com#Especialista
:Especialista rdf:type owl:Class ;
              rdfs:subClassOf :AgenteHumano ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty [ owl:inverseOf gufo:mediates
                                               ] ;
                                owl:someValuesFrom :DefinicaoNormativa
                              ] .


###  http://example.com#Justica
:Justica rdf:type owl:Class ;
         rdfs:subClassOf :Valor .


###  http://example.com#NaoMaleficencia
:NaoMaleficencia rdf:type owl:Class ;
                 rdfs:subClassOf :Valor .


###  http://example.com#Norma
:Norma rdf:type owl:Class ;
       rdfs:subClassOf gufo:Relator ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty gufo:mediates ;
                         owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                         owl:onClass :AgenteMoral
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf gufo:inheresIn
                                        ] ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :RestricaoDeontica
                       ] .


###  http://example.com#Obrigacao
:Obrigacao rdf:type owl:Class ;
           rdfs:subClassOf :RestricaoDeontica .


###  http://example.com#OrgaoRegulador
:OrgaoRegulador rdf:type owl:Class ;
                rdfs:subClassOf :AgenteColetivo ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty [ owl:inverseOf gufo:mediates
                                                 ] ;
                                  owl:someValuesFrom :Responsabilizacao
                                ] .


###  http://example.com#Permissao
:Permissao rdf:type owl:Class ;
           rdfs:subClassOf :RestricaoDeontica .


###  http://example.com#Proibicao
:Proibicao rdf:type owl:Class ;
           rdfs:subClassOf :RestricaoDeontica .


###  http://example.com#QuebraNormativa
:QuebraNormativa rdf:type owl:Class ;
                 rdfs:subClassOf gufo:Situation .


###  http://example.com#Responsabilizacao
:Responsabilizacao rdf:type owl:Class ;
                   rdfs:subClassOf gufo:Relator ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty gufo:mediates ;
                                     owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :Agente
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty gufo:mediates ;
                                     owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :OrgaoRegulador
                                   ] .


###  http://example.com#RestricaoDeontica
:RestricaoDeontica rdf:type owl:Class ;
                   rdfs:subClassOf gufo:IntrinsicMode ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty gufo:inheresIn ;
                                     owl:someValuesFrom :Norma
                                   ] .


###  http://example.com#Usuario
:Usuario rdf:type owl:Class ;
         rdfs:subClassOf :AgenteHumano ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty [ owl:inverseOf gufo:mediates
                                          ] ;
                           owl:someValuesFrom :EcossistemaDeIA
                         ] .


###  http://example.com#Valor
:Valor rdf:type owl:Class ;
       rdfs:subClassOf gufo:Quality .


