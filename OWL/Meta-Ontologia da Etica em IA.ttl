#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :AgenteArtificial
                :AgenteHumano
                :AgenteOrganizacional
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Obrigacao
                :Permissao
