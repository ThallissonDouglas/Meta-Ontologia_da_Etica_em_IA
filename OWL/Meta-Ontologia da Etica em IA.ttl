@prefix : <http://example.com#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.com#> .

<http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#> rdf:type owl:Ontology ;
                                                           owl:imports gufo: .

#################################################################
#    Object Properties
#################################################################

###  http://purl.org/net/ethical-ai/meta##interage_com
<http://purl.org/net/ethical-ai/meta##interage_com> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://purl.org/net/ethical-ai/meta##Usuario> ;
                                                    rdfs:range <http://purl.org/net/ethical-ai/meta##AgenteArtificial> .


###  http://purl.org/net/ethical-ai/meta##responsabiliza
<http://purl.org/net/ethical-ai/meta##responsabiliza> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <http://purl.org/net/ethical-ai/meta##OrganizacaoReguladora> ;
                                                      rdfs:range <http://purl.org/net/ethical-ai/meta##Agente> .


#################################################################
#    Classes
#################################################################

###  http://purl.org/net/ethical-ai/meta##Acao
<http://purl.org/net/ethical-ai/meta##Acao> rdf:type owl:Class ;
                                            rdfs:subClassOf gufo:Event ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                             ] ;
                                                              owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##EcossistemaDeIA>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                             ] ;
                                                              owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Usuario>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                             ] ;
                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                              owl:onClass <http://purl.org/net/ethical-ai/meta##AgenteArtificial>
                                                            ] .


###  http://purl.org/net/ethical-ai/meta##AcaoMoral
<http://purl.org/net/ethical-ai/meta##AcaoMoral> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <http://purl.org/net/ethical-ai/meta##Acao>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                                                             ] ;
                                                                                              owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Norma>
                                                                                            ]
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                                                             ] ;
                                                                                              owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##AgenteMoral>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] .


###  http://purl.org/net/ethical-ai/meta##Agente
<http://purl.org/net/ethical-ai/meta##Agente> rdf:type owl:Class ;
                                              rdfs:subClassOf gufo:FunctionalComplex ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty [ owl:inverseOf gufo:mediates
                                                                               ] ;
                                                                owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Responsabilizacao>
                                                              ] .


###  http://purl.org/net/ethical-ai/meta##AgenteArtificial
<http://purl.org/net/ethical-ai/meta##AgenteArtificial> rdf:type owl:Class ;
                                                        rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Agente> ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty gufo:participatedIn ;
                                                                          owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Acao>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf gufo:mediates
                                                                                         ] ;
                                                                          owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##EcossistemaDeIA>
                                                                        ] .


###  http://purl.org/net/ethical-ai/meta##AgenteHumano
<http://purl.org/net/ethical-ai/meta##AgenteHumano> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Agente> .


###  http://purl.org/net/ethical-ai/meta##AgenteMoral
<http://purl.org/net/ethical-ai/meta##AgenteMoral> rdf:type owl:Class ;
                                                   owl:equivalentClass [ owl:intersectionOf ( <http://purl.org/net/ethical-ai/meta##Agente>
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty gufo:participatedIn ;
                                                                                                owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##AcaoMoral>
                                                                                              ]
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty [ owl:inverseOf gufo:mediates
                                                                                                               ] ;
                                                                                                owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Norma>
                                                                                              ]
                                                                                            ) ;
                                                                         rdf:type owl:Class
                                                                       ] .


###  http://purl.org/net/ethical-ai/meta##AgenteOrganizacional
<http://purl.org/net/ethical-ai/meta##AgenteOrganizacional> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Agente> .


###  http://purl.org/net/ethical-ai/meta##AplicacaoDeResponsabilidade
<http://purl.org/net/ethical-ai/meta##AplicacaoDeResponsabilidade> rdf:type owl:Class ;
                                                                   rdfs:subClassOf gufo:Event ,
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Responsabilizacao>
                                                                                   ] ,
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Agente>
                                                                                   ] ,
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf gufo:participatedIn
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##OrganizacaoReguladora>
                                                                                   ] .


###  http://purl.org/net/ethical-ai/meta##AplicacaoNormativa
<http://purl.org/net/ethical-ai/meta##AplicacaoNormativa> rdf:type owl:Class ;
                                                          rdfs:subClassOf gufo:Event ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty [ owl:inverseOf gufo:wasCreatedIn
                                                                                           ] ;
                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                            owl:onClass <http://purl.org/net/ethical-ai/meta##Norma>
                                                                          ] .


###  http://purl.org/net/ethical-ai/meta##Beneficencia
<http://purl.org/net/ethical-ai/meta##Beneficencia> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Valor> .


###  http://purl.org/net/ethical-ai/meta##EcossistemaDeIA
<http://purl.org/net/ethical-ai/meta##EcossistemaDeIA> rdf:type owl:Class ;
                                                       rdfs:subClassOf gufo:Relator ,
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty gufo:mediates ;
                                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://purl.org/net/ethical-ai/meta##AgenteArtificial>
                                                                       ] ,
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty gufo:mediates ;
                                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://purl.org/net/ethical-ai/meta##Usuario>
                                                                       ] .


###  http://purl.org/net/ethical-ai/meta##Especialista
<http://purl.org/net/ethical-ai/meta##Especialista> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##AgenteHumano> .


###  http://purl.org/net/ethical-ai/meta##Justica
<http://purl.org/net/ethical-ai/meta##Justica> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Valor> .


###  http://purl.org/net/ethical-ai/meta##NaoMaleficencia
<http://purl.org/net/ethical-ai/meta##NaoMaleficencia> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##Valor> .


###  http://purl.org/net/ethical-ai/meta##Norma
<http://purl.org/net/ethical-ai/meta##Norma> rdf:type owl:Class ;
                                             rdfs:subClassOf gufo:Relator ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf gufo:inheresIn
                                                                              ] ;
                                                               owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Valor>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty gufo:historicallyDependsOn ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##Especialista>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty gufo:mediates ;
                                                               owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##AgenteMoral>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty gufo:wasCreatedIn ;
                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##AplicacaoNormativa>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf gufo:inheresIn
                                                                              ] ;
                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##RestricaoDeontica>
                                                             ] .


###  http://purl.org/net/ethical-ai/meta##Obrigacao
<http://purl.org/net/ethical-ai/meta##Obrigacao> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##RestricaoDeontica> .


###  http://purl.org/net/ethical-ai/meta##Omissao
<http://purl.org/net/ethical-ai/meta##Omissao> rdf:type owl:Class ;
                                               owl:equivalentClass [ owl:intersectionOf ( <http://purl.org/net/ethical-ai/meta##AcaoMoral>
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty [ owl:inverseOf gufo:manifestedIn
                                                                                                           ] ;
                                                                                            owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Proibicao>
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] .


###  http://purl.org/net/ethical-ai/meta##OrganizacaoReguladora
<http://purl.org/net/ethical-ai/meta##OrganizacaoReguladora> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##AgenteOrganizacional> ,
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty [ owl:inverseOf gufo:mediates
                                                                                              ] ;
                                                                               owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Responsabilizacao>
                                                                             ] .


###  http://purl.org/net/ethical-ai/meta##Permissao
<http://purl.org/net/ethical-ai/meta##Permissao> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##RestricaoDeontica> .


###  http://purl.org/net/ethical-ai/meta##Proibicao
<http://purl.org/net/ethical-ai/meta##Proibicao> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##RestricaoDeontica> .


###  http://purl.org/net/ethical-ai/meta##QuebraNormativa
<http://purl.org/net/ethical-ai/meta##QuebraNormativa> rdf:type owl:Class ;
                                                       rdfs:subClassOf gufo:Situation .


###  http://purl.org/net/ethical-ai/meta##Responsabilizacao
<http://purl.org/net/ethical-ai/meta##Responsabilizacao> rdf:type owl:Class ;
                                                         rdfs:subClassOf gufo:Relator ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty gufo:mediates ;
                                                                           owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                           owl:onClass <http://purl.org/net/ethical-ai/meta##Agente>
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty gufo:mediates ;
                                                                           owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                           owl:onClass <http://purl.org/net/ethical-ai/meta##OrganizacaoReguladora>
                                                                         ] .


###  http://purl.org/net/ethical-ai/meta##RestricaoDeontica
<http://purl.org/net/ethical-ai/meta##RestricaoDeontica> rdf:type owl:Class ;
                                                         owl:equivalentClass [ rdf:type owl:Class ;
                                                                               owl:unionOf ( <http://purl.org/net/ethical-ai/meta##Obrigacao>
                                                                                             <http://purl.org/net/ethical-ai/meta##Permissao>
                                                                                             <http://purl.org/net/ethical-ai/meta##Proibicao>
                                                                                           )
                                                                             ] ;
                                                         rdfs:subClassOf gufo:IntrinsicMode ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty gufo:historicallyDependsOn ;
                                                                           owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                           owl:onClass <http://purl.org/net/ethical-ai/meta##Especialista>
                                                                         ] ,
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty gufo:inheresIn ;
                                                                           owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                           owl:onClass <http://purl.org/net/ethical-ai/meta##Norma>
                                                                         ] .


###  http://purl.org/net/ethical-ai/meta##Usuario
<http://purl.org/net/ethical-ai/meta##Usuario> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.org/net/ethical-ai/meta##AgenteHumano> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty gufo:participatedIn ;
                                                                 owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##Acao>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf gufo:mediates
                                                                                ] ;
                                                                 owl:someValuesFrom <http://purl.org/net/ethical-ai/meta##EcossistemaDeIA>
                                                               ] .


###  http://purl.org/net/ethical-ai/meta##Valor
<http://purl.org/net/ethical-ai/meta##Valor> rdf:type owl:Class ;
                                             rdfs:subClassOf gufo:Quality ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty gufo:historicallyDependsOn ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##Especialista>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty gufo:inheresIn ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass <http://purl.org/net/ethical-ai/meta##Norma>
                                                             ] .


