@prefix : <http://example.com#>.
@prefix gufo: <http://purl.org/nemo/gufo#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<http://example.com> rdf:type owl:Ontology;
    owl:imports gufo:.
:Agente rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:FunctionalComplex;
    rdfs:label "Agente"@en.
:AgenteHumano rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "AgenteHumano"@en.
:AgenteArtificial rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "AgenteArtificial"@en.
:AgenteMoral rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "AgenteMoral"@en.
:Acao rdf:type owl:Class, gufo:EventType, owl:NamedIndividual;
    rdfs:subClassOf gufo:Event;
    rdfs:label "Acao"@en.
:AcaoMoral rdf:type owl:Class, gufo:EventType, owl:NamedIndividual;
    rdfs:label "AcaoMoral"@en.
:AplicacaoNormativa rdf:type owl:Class, gufo:SituationType, owl:NamedIndividual;
    rdfs:subClassOf gufo:Situation;
    rdfs:label "AplicacaoNormativa"@en.
:Usuario rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "Usuario"@en.
:AgenteColetivo rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "AgenteColetivo"@en.
:OrgaoRegulador rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "OrgaoRegulador"@en.
:EcossistemaDeIA rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Relator;
    rdfs:label "EcossistemaDeIA"@en.
:Responsabilizacao rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Relator;
    rdfs:label "Responsabilizacao"@en.
:AplicacaoDeResponsabilidade rdf:type owl:Class, gufo:EventType, owl:NamedIndividual;
    rdfs:subClassOf gufo:Event;
    rdfs:label "AplicacaoDeResponsabilidade"@en.
:QuebraNormativa rdf:type owl:Class, gufo:SituationType, owl:NamedIndividual;
    rdfs:subClassOf gufo:Situation;
    rdfs:label "QuebraNormativa"@en.
:RestricaoDeontica rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:IntrinsicMode;
    rdfs:label "RestricaoDeontica"@en.
:Permissao rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Permissao"@en.
:Obrigacao rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Obrigacao"@en.
:Priobicao rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Priobicao"@en.
:Valor rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Quality;
    rdfs:label "Valor"@en.
:NaoMaleficencia rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "NaoMaleficencia"@en.
:Beneficencia rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Beneficencia"@en.
:Justica rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Justica"@en.
:Especialista rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "Especialista"@en.
:Norma rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Relator;
    rdfs:label "Norma"@en.
:AgenteArtificial rdfs:subClassOf :Agente.
:AgenteHumano rdfs:subClassOf :Agente.
:AgenteMoral rdfs:subClassOf :Agente.
:AcaoMoral rdfs:subClassOf :Acao.
:Usuario rdfs:subClassOf :AgenteHumano.
:AgenteColetivo rdfs:subClassOf :Agente.
:OrgaoRegulador rdfs:subClassOf :AgenteColetivo.
:Obrigacao rdfs:subClassOf :RestricaoDeontica.
:Permissao rdfs:subClassOf :RestricaoDeontica.
:Priobicao rdfs:subClassOf :RestricaoDeontica.
:NaoMaleficencia rdfs:subClassOf :Valor.
:Justica rdfs:subClassOf :Valor.
:Beneficencia rdfs:subClassOf :Valor.
:Especialista rdfs:subClassOf :AgenteHumano.
:responsabiliza rdf:type owl:ObjectProperty;
    rdfs:domain :OrgaoRegulador;
    rdfs:range :Agente;
    rdfs:label "responsabiliza"@en;
    rdf:type gufo:MaterialRelationshipType.
:interage_com rdf:type owl:ObjectProperty;
    rdfs:domain :Usuario;
    rdfs:range :AgenteArtificial;
    rdfs:label "interage_com"@en;
    rdf:type gufo:MaterialRelationshipType.
:AgenteArtificial rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :EcossistemaDeIA
].
:EcossistemaDeIA rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :AgenteArtificial
].
:Usuario rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :EcossistemaDeIA
].
:EcossistemaDeIA rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Usuario
].
:Acao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:manifestedIn ];
  owl:someValuesFrom :EcossistemaDeIA
].
:OrgaoRegulador rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :Responsabilizacao
].
:Responsabilizacao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :OrgaoRegulador
].
:Agente rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :Responsabilizacao
].
:Responsabilizacao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Agente
].
:AplicacaoDeResponsabilidade rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:manifestedIn ];
  owl:someValuesFrom :Responsabilizacao
], [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:participatedIn ];
  owl:someValuesFrom :Agente
], [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:participatedIn ];
  owl:someValuesFrom :OrgaoRegulador
].
:Acao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:wasCreatedIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :AgenteArtificial
].
:AgenteArtificial rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:wasCreatedIn;
  owl:someValuesFrom :Acao
].
:Acao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:participatedIn ];
  owl:someValuesFrom :Usuario
].
:Usuario rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:participatedIn;
  owl:someValuesFrom :Acao
].
:AcaoMoral rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:participatedIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :AgenteMoral
].
:AgenteMoral rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:participatedIn;
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :AcaoMoral
].
:Norma rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :RestricaoDeontica
].
:RestricaoDeontica rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Norma
].
:Norma rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:someValuesFrom :Valor
].
:Valor rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Norma
], [
  rdf:type owl:Restriction;
  owl:onProperty gufo:historicallyDependsOn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Especialista
].
:RestricaoDeontica rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:historicallyDependsOn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Especialista
].
:AgenteMoral rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :Norma
].
:Norma rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger;
  owl:onClass :AgenteMoral
].
:AcaoMoral rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:manifestedIn ];
  owl:someValuesFrom :Norma
].
