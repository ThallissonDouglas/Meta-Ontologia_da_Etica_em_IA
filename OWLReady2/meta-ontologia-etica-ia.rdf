    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#interage_com -->

    <owl:ObjectProperty rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#interage_com">
        <rdfs:domain rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Usuario"/>
        <rdfs:range rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AgenteArtificial"/>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#responsabiliza -->

    <owl:ObjectProperty rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#responsabiliza">
        <rdfs:domain rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#OrganizacaoReguladora"/>
        <rdfs:range rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Agente"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Acao -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Acao">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#manifestedIn"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#EcossistemaDeIA"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#participatedIn"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Usuario"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#isEventProperPartOf"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AplicacaoNormativa"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#participatedIn"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AgenteArtificial"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AcaoMoral -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AcaoMoral">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Acao"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#isEventProperPartOf"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AplicacaoNormativa"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#manifestedIn"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Norma"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#participatedIn"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AgenteMoral"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Agente -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Agente">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#FunctionalComplex"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
