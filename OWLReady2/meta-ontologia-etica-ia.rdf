    </owl:Class>
    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Omissao -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Omissao">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AcaoMoral"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#manifestedIn"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Proibicao"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


