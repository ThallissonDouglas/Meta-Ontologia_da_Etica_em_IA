    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#EcossistemaDeIA -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#EcossistemaDeIA">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Relator"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AgenteArtificial"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Usuario"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Especialista -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Especialista">
