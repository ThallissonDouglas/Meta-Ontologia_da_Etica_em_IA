    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AplicacaoNormativa -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#AplicacaoNormativa">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Event"/>
