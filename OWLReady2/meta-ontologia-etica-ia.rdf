    <!-- http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Responsabilizacao -->

    <owl:Class rdf:about="http://purl.org/net/ethical-ai/meta-ontologia-etica-ia#Responsabilizacao">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Relator"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
